page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft YaHei', sans-serif;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.1);
}

.title {
  font-size: 36rpx;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #667eea;
  text-align: center;
  margin-bottom: 15rpx;
}

.btn {
  display: inline-block;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  border: none;
  border-radius: 50rpx;
  text-align: center;
  margin: 15rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-success {
  background: #28a745;
  color: white;
}

.btn-warning {
  background: #ffc107;
  color: #333;
}

.btn-danger {
  background: #dc3545;
  color: white;
}

.btn-info {
  background: #17a2b8;
  color: white;
}

.btn-small {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
}

.btn-block {
  width: 100%;
  margin: 20rpx 0;
}

.warning-box {
  background: #fff3cd;
  border-left: 8rpx solid #ffc107;
  padding: 24rpx;
  margin: 30rpx 0;
  border-radius: 10rpx;
}

.safety-alert {
  background: #f8d7da;
  border: 4rpx solid #dc3545;
  padding: 24rpx;
  margin: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
}

.level-badge {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.level-L1 { background: #f8d7da; color: #dc3545; }
.level-L2 { background: #fff3cd; color: #856404; }
.level-L3 { background: #cce5ff; color: #004085; }
.level-L4 { background: #d4edda; color: #155724; }
.level-L5 { background: #e2e3e5; color: #383d41; }

.progress-bar {
  background: #e9ecef;
  height: 24rpx;
  border-radius: 12rpx;
  margin: 30rpx 0;
  overflow: hidden;
}

.progress-fill {
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.5s;
}

.step-card {
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 30rpx 0;
  border: 4rpx solid #667eea;
}

.step-number {
  display: inline-block;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.step-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  margin: 20rpx 0;
}

.center {
  text-align: center;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-10 {
  gap: 20rpx;
}

.gap-15 {
  gap: 30rpx;
}

.mt-10 { margin-top: 20rpx; }
.mt-15 { margin-top: 30rpx; }
.mt-20 { margin-top: 40rpx; }
.mb-10 { margin-bottom: 20rpx; }
.mb-15 { margin-bottom: 30rpx; }
.mb-20 { margin-bottom: 40rpx; }

.text-center { text-align: center; }
.text-primary { color: #667eea; }
.text-success { color: #28a745; }
.text-warning { color: #ffc107; }
.text-danger { color: #dc3545; }
.text-muted { color: #666; }

.font-bold { font-weight: bold; }
.font-24 { font-size: 24rpx; }
.font-28 { font-size: 28rpx; }
.font-32 { font-size: 32rpx; }
.font-36 { font-size: 36rpx; }
.font-48 { font-size: 48rpx; }